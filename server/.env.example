# Copy to .env and fill in. Only one provider's key is needed.

# openai | gemini | mock   (mock = passthrough, no key, for local testing)
LLM_PROVIDER=mock

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Content scope
SL_LANGS=fr,de,en,nl,es
SL_LEVELS=A2,B1,B2,C1
SL_POOL=4
SL_MAX_PARAS=8

# Content is prepared manually via the admin dashboard by default. Set to 1 to
# auto-discover + process on startup and daily (then SL_BUILD_HOUR applies).
SL_AUTO_BUILD=0
SL_BUILD_HOUR=4

# Host loopback port for the prod compose (reverse-proxied by Caddy)
SL_PORT=9990

# SQLite location (the Docker image defaults to /data/sidelearn.db on a volume)
DB_PATH=./sidelearn.db

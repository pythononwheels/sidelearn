{
  "name": "sidelearn",
  "version": "0.6.7",
  "description": "Read foreign-language web pages with inline, CEFR-aware reading help powered by a local LLM (LM Studio).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "prepare": "wxt prepare",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:wordlists": "node scripts/build-wordlists.mjs"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wxt": "^0.19.27"
  },
  "dependencies": {
    "preact": "^10.25.4"
  }
}
